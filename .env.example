# Local server
NODE_ENV=development
PORT=3000

# Optional Twitch live-status integration
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Durable anonymous sync (required together in production)
RUNALERT_CONFIG_STORE=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RUNALERT_CREDENTIAL_PEPPER=

# Optional dashboard telemetry; leave blank to disable
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Stable release manifest
RUNALERT_MAC_DMG_URL=
RUNALERT_MAC_ZIP_URL=
RUNALERT_WINDOWS_STORE_URL=
RUNALERT_RELEASE_PUBLISHED_AT=
